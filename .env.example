# Frontend runtime
VITE_ASR_MT_HTTP_URL=http://localhost:8001
VITE_ASR_MT_WS_URL=ws://localhost:8001/ws/asr-mt
VITE_PEER_SERVER_HOST=localhost
VITE_PEER_SERVER_PORT=9000
VITE_PEER_SERVER_PATH=/peerjs
VITE_PEER_SERVER_SECURE=false
# JSON array. Include TURN in stage/prod.
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# Backend (services/asr-mt)
SESSION_SIGNING_KEY=replace-with-strong-random-key
SESSION_TTL_SECONDS=28800
ALLOWED_ORIGINS=http://localhost:3000
AUDIT_LOG_PATH=runtime/audit-log.jsonl
ASR_BACKEND=mock
MT_BACKEND=mock
LOG_LEVEL=info
MAX_TRANSLATION_CHARS_PER_SESSION=20000
MAX_TTS_CHARS_PER_SESSION=12000
ROOM_PARTICIPANT_TTL_SECONDS=180
MAX_TELEMETRY_EVENTS_PER_SESSION=500
