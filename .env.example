# Frontend runtime
VITE_ASR_MT_HTTP_URL=http://localhost:8001
VITE_ASR_MT_WS_URL=ws://localhost:8001/ws/asr-mt
VITE_PEER_SERVER_HOST=localhost
VITE_PEER_SERVER_PORT=9000
VITE_PEER_SERVER_PATH=/peerjs
VITE_PEER_SERVER_SECURE=false
VITE_CALL_TOPOLOGY=p2p
VITE_SFU_JOIN_URL=
VITE_ENABLE_INSERTABLE_E2EE=false
VITE_REQUIRE_INSERTABLE_E2EE=false
VITE_E2EE_SHARED_KEY=
# JSON array. Include TURN in stage/prod.
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# Backend (services/asr-mt)
SESSION_SIGNING_KEY=replace-with-strong-random-key
SESSION_TTL_SECONDS=28800
ALLOWED_ORIGINS=http://localhost:3000
AUDIT_LOG_PATH=runtime/audit-log.jsonl
ASR_BACKEND=mock
# ASR_BACKEND aliases: streaming=vosk, quality=faster-whisper
VOSK_MODEL_PATH=
VOSK_MODEL_NAME=vosk-model-small-en-us-0.15
MT_BACKEND=mock
MT_MICRO_BATCH_WINDOW_MS=35
MT_MICRO_BATCH_MAX_ITEMS=4
MT_MICRO_BATCH_MAX_CHARS=220
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_SESSION_PER_WINDOW=20
RATE_LIMIT_CHAT_TRANSLATE_PER_WINDOW=120
RATE_LIMIT_CHAT_TTS_PER_WINDOW=120
RATE_LIMIT_ROOMS_PER_WINDOW=60
RATE_LIMIT_TELEMETRY_PER_WINDOW=240
RATE_LIMIT_WS_MESSAGES_PER_WINDOW=1200
LOG_LEVEL=info
MAX_TRANSLATION_CHARS_PER_SESSION=20000
MAX_TTS_CHARS_PER_SESSION=12000
ROOM_PARTICIPANT_TTL_SECONDS=180
MAX_TELEMETRY_EVENTS_PER_SESSION=500
STORAGE_BACKEND=memory
SQLITE_DB_PATH=runtime/asr-mt.sqlite3
